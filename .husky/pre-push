cd "$(git rev-parse --show-toplevel)"

# Build + test backend
pnpm build
pnpm test

# Build + test frontend only when web app changes are being pushed
if git diff --name-only "$(git merge-base HEAD @{upstream} 2>/dev/null || echo HEAD~1)" HEAD | grep -q '^apps/web/'; then
  pnpm --filter web build
  pnpm --filter web test
fi
